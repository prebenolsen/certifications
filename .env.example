# Supabase — copy to `.env.local` for local dev, and add both as GitHub Actions
# repository secrets (Settings → Secrets and variables → Actions) for the deploy.
#
# Leave these unset to run the app in guest-only mode (localStorage, no sign-in).
# Both values are safe to expose in a client bundle; the anon key is public and
# is gated by Row Level Security. See supabase/supabase-readme.md.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
